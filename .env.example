# ── Database ──────────────────────────────────────────────
# Leave commented out to use the local JSON fallback (data/db.json)
# Set to a MongoDB Atlas connection string to use MongoDB
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/campusflow

# ── Auth ──────────────────────────────────────────────────
# Secret used to sign session tokens (generate with: openssl rand -base64 32)
# AUTH_SECRET=your_secret_here
